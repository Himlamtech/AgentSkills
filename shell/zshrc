# =========================================
# Guard: only run for interactive shells
# (Avoid breaking scp/rsync/remote commands)
# =========================================
[[ -o interactive ]] || return

# =========================================
# Oh-My-Zsh
# =========================================
export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
ZSH_THEME="${ZSH_THEME:-robbyrussell}"

# Plugins: syntax-highlighting should be last
plugins=(
  git
  zsh-completions
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# Optional: reduce OMZ update noise/latency on servers
export DISABLE_AUTO_UPDATE="true"
export DISABLE_UPDATE_PROMPT="true"

# Load OMZ
if [ -f "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# =========================================
# PATH (portable)
# - prefer per-user bin first
# - add brew paths if present (macOS)
# =========================================
path_prepend() { [[ -d "$1" ]] && export PATH="$1:$PATH"; }
path_append()  { [[ -d "$1" ]] && export PATH="$PATH:$1"; }

# User-local bins
path_prepend "$HOME/.local/bin"
path_prepend "$HOME/bin"

# macOS Homebrew (Apple Silicon + Intel)
path_prepend "/opt/homebrew/bin"
path_prepend "/usr/local/bin"

# Optional Homebrew Python shim (only if exists)
path_prepend "/opt/homebrew/opt/python@3.12/libexec/bin"

# Antigravity (if installed)
path_prepend "$HOME/.antigravity/antigravity/bin"

# Optional extra env (only if exists)
[ -f "$HOME/.local/bin/env" ] && source "$HOME/.local/bin/env"

# =========================================
# Completion tuning (portable, avoids lag)
# =========================================
autoload -Uz compinit
# Cache completion results
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$HOME/.zsh/cache"
zstyle ':completion:*' menu select

# Ensure cache dir exists
mkdir -p "$HOME/.zsh/cache" 2>/dev/null

# Initialize completion (safe)
# -C: skip compaudit checks (faster); remove -C if you prefer strict security checks
compinit -C

# =========================================
# Autosuggestions tuning
# =========================================
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
# Accept suggestion by Ctrl+E
# (Note: requires zsh-autosuggestions loaded; harmless if not)
bindkey '^E' autosuggest-accept 2>/dev/null

# =========================================
# Grep coloring (portable)
# =========================================
if command -v ggrep >/dev/null 2>&1; then
  alias grep='ggrep --color=auto'
elif grep --help 2>&1 | command grep -q -- '--color' 2>/dev/null; then
  alias grep='grep --color=auto'
fi

# =========================================
# macOS-specific: SSH agent keychain integration (guarded)
# =========================================
if [[ "$OSTYPE" == "darwin"* ]] && command -v ssh-add >/dev/null 2>&1; then
  export APPLE_SSH_ADD_BEHAVIOR=openssh

  # Load keys from keychain silently (if supported)
  ssh-add --apple-load-keychain >/dev/null 2>&1

  # Load a specific key if present
  if [ -f "$HOME/.ssh/himlam_macbook" ]; then
    ssh-add -l 2>/dev/null | command grep -q "himlam_macbook" || \
      ssh-add --apple-use-keychain "$HOME/.ssh/himlam_macbook" >/dev/null 2>&1
  fi
fi

# =========================================
# SDKMAN (portable)
# =========================================
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]] && source "$SDKMAN_DIR/bin/sdkman-init.sh"

# =========================================
# Aliases / functions (portable, minimal-safe)
# =========================================
# Recover a usable TERM only for real interactive terminals. This avoids
# breaking non-interactive shells where TERM=dumb is expected.
if [[ -o interactive ]] && [[ -t 1 ]] && [[ "${TERM:-}" == "dumb" ]]; then
  export TERM="xterm-256color"
fi

cls() {
  # Use ANSI directly so screen clearing never depends on terminfo availability.
  printf '\033[2J\033[H'
}

alias ll='ls -alF'
alias la='ls -A'

# Safer file ops (optional; comment out if you dislike prompts)
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Python venv helpers
alias venv='source .venv/bin/activate'
alias mkvenv='python -m venv .venv'
alias pipall='pip install -r requirements.txt'

# Reload
alias reload='source ~/.zshrc'

